model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  ascent    Ascent   @relation(fields: [ascentId], references: [id])
  ascentId  String

  @@index([authorId])
  @@index([ascentId])
}

model Photo {
  id       String  @id @default(cuid())
  url      String
  ascent   Ascent? @relation(fields: [ascentId], references: [id])
  ascentId String?
  Event    Event[]

  @@index([ascentId])
}

model Event {
  id              String    @id @default(cuid())
  title           String
  text            String
  date            String?   
  createdAt       DateTime  @default(now())
  author          User      @relation(fields: [authorId], references: [id])
  authorId        String
  coverPhoto      Photo?  @relation(fields: [coverPhotoId], references: [id])
  coverPhotoId    String? 
  type            String
  isPinned        Boolean   @default(false)

  @@index([authorId])
}

