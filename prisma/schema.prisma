generator client {
  provider      = "prisma-client-js"
  output   = "../app/generated/prisma"
  binaryTargets = ["darwin-arm64", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
}

model User {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  firstName           String
  lastName            String
  password            String
  experienceLevel     String?
  accepted            Boolean                  @default(false)
  isAdmin             Boolean                  @default(false)
  createdAt           DateTime                 @default(now())
  authoredAscents     Ascent[]                 @relation("authoredAscents")
  participatedAscents Ascent[]
  comments            Comment[]
  Events              Event[]
}

model Ascent {
  id                       String             @id @default(cuid())
  route                    String
  difficulty               String
  routeLength              Float              @default(0)
  date                     String
  text                     String?
  createdAt                DateTime           @default(now())
  author                   User               @relation("authoredAscents", fields: [authorId], references: [id])
  authorId                 String
  photos                   Photo[]
  comments                 Comment[]
  registeredParticipants   User[]
  unregisteredParticipants UnregisteredParticipation[] @relation("AscentUnregisteredParticipants")

  @@index([authorId])
}

model UnregisteredParticipation {
  id        String    @id @default(cuid())
  name      String
  ascentId  String
  ascent    Ascent    @relation("AscentUnregisteredParticipants", fields: [ascentId], references: [id], onDelete: Cascade)

  @@index([ascentId])
}

